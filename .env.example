# ============================================================
# TENACIOUS CONVERSION ENGINE — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# === KILL SWITCH (MUST STAY FALSE UNTIL TENACIOUS APPROVES) ===
LIVE_MODE=false
STAFF_SINK_EMAIL=sink@tenacious-challenge.example.com
STAFF_SINK_NUMBER=+254700000000

# === LLM — EVAL TIER (Claude Sonnet 4.6) ===
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# === LLM — DEV TIER (OpenRouter: Qwen3 / DeepSeek V3) ===
# Get from: openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# === EMAIL — RESEND (Primary outreach channel) ===
# Signup: resend.com (free tier, no credit card)
# Steps: Create account → Add domain OR use sandbox → Copy API key
# Verify: Send one test email to yourself, confirm receipt
RESEND_API_KEY=re_REPLACE_ME
SENDER_EMAIL=outreach@your-domain.com
SENDER_NAME=Tenacious Consulting

# === SMS — AFRICA'S TALKING (Secondary channel, warm leads only) ===
# Signup: account.africastalking.com/apps/sandbox
# Steps: Create account → Go to Sandbox → Create virtual short code → Copy API key
# Verify: Send test SMS from your number to short code, check webhook POST
AT_USERNAME=sandbox
AT_API_KEY=REPLACE_ME
AT_SENDER_ID=TENACIOUS

# === CRM — HUBSPOT DEVELOPER SANDBOX ===
# Signup: developers.hubspot.com (free, no credit card)
# Steps: Create account → Create App → Settings → Private App Tokens → Generate token
# Scopes needed: crm.objects.contacts.read, crm.objects.contacts.write, crm.objects.notes.write
# Verify: send a test request through your HubSpot MCP bridge and confirm record created
HUBSPOT_ACCESS_TOKEN=pat-na1-REPLACE_ME
HUBSPOT_TRANSPORT=mcp
HUBSPOT_MCP_URL=http://localhost:8080/mcp

# === CALENDAR — CAL.COM (Self-hosted Docker) ===
# Setup: docker compose up -d (from official cal.com repo)
# Steps: docker run → http://localhost:3000 → Create account → Create event type "Discovery Call 30min" → Copy API key
# Verify: Book one test slot via public booking URL
CALCOM_URL=http://localhost:3000
CALCOM_API_KEY=REPLACE_ME
CALCOM_EVENT_TYPE_ID=1

# === OBSERVABILITY — LANGFUSE ===
# Signup: cloud.langfuse.com (free tier, 50K traces)
# Steps: Create account → New Project → Settings → Copy public + secret keys
# Verify: Run python eval/harness.py → check cloud.langfuse.com for trace
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_HOST=https://cloud.langfuse.com
